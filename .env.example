# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/bewerbungsfinder"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL="https://your-domain.com"
NEXTAUTH_SECRET=""   # openssl rand -base64 32

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."

# ─── Job Providers ────────────────────────────────────────────────────────────
# Leave empty to use the mock provider (dev mode)
RAPID_API_KEY=""     # RapidAPI key for JSearch (covers Indeed, LinkedIn etc.)

# ─── Email Notifications (Resend) ────────────────────────────────────────────
RESEND_API_KEY=""    # Get at resend.com — leave empty to disable emails
EMAIL_FROM="BewerbungsFinder <noreply@yourdomain.com>"

# ─── File Storage ─────────────────────────────────────────────────────────────
STORAGE_PROVIDER="local"   # local | s3
STORAGE_LOCAL_PATH="./uploads"

# ─── Automation (Cron) ────────────────────────────────────────────────────────
CRON_SECRET=""       # openssl rand -base64 32 — protects /api/cron endpoint
