generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
}

enum DocumentType {
  CV
  COVER_LETTER
  CERTIFICATE
  PORTFOLIO
  OTHER
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  FREELANCE
  INTERNSHIP
}

enum WorkMode {
  REMOTE
  HYBRID
  ONSITE
}

enum JobStatus {
  OPEN
  CLOSED
  UNKNOWN
}

enum MatchStatus {
  PENDING
  ANALYZED
  APPROVED
  REJECTED
  SKIPPED
}

enum ApplicationStatus {
  DRAFT
  READY
  SUBMITTED
  ACKNOWLEDGED
  REJECTED
  INTERVIEW
  OFFER
  WITHDRAWN
}

enum ApplicationMethod {
  EMAIL
  PORTAL
  MANUAL
}

enum LogLevel {
  INFO
  WARN
  ERROR
}

// ─── AUTH ─────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  passwordHash  String?
  role          UserRole  @default(USER)
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  profile      UserProfile?
  preferences  UserPreference?
  availability AvailabilityWindow[]
  documents    Document[]
  jobMatches   JobMatch[]
  applications Application[]
  accounts     Account[]
  sessions     Session[]

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── USER PROFILE ─────────────────────────────────────────────────────────────

model UserProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  firstName    String
  lastName     String
  phone        String?
  location     String?
  linkedinUrl  String?
  githubUrl    String?
  portfolioUrl String?
  summary      String?  @db.Text
  skills       String[]
  languages    String[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── USER PREFERENCES ─────────────────────────────────────────────────────────

model UserPreference {
  id                    String     @id @default(cuid())
  userId                String     @unique
  jobTitles             String[]
  industries            String[]
  locations             String[]
  minSalary             Int?
  maxSalary             Int?
  currency              String     @default("EUR")
  jobTypes              JobType[]
  workModes             WorkMode[]
  minMatchScore         Int        @default(70)
  maxApplicationsPerDay Int        @default(5)
  autoApply             Boolean    @default(false)
  blacklistedCompanies  String[]
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AvailabilityWindow {
  id        String   @id @default(cuid())
  userId    String
  dayOfWeek Int      // 0=Sunday … 6=Saturday
  startHour Int      // 0–23
  endHour   Int      // 0–23
  timezone  String   @default("Europe/Berlin")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── DOCUMENTS ────────────────────────────────────────────────────────────────

model Document {
  id          String       @id @default(cuid())
  userId      String
  type        DocumentType
  name        String
  storagePath String
  mimeType    String
  sizeBytes   Int
  parsedText  String?      @db.Text
  metadata    Json?
  isActive    Boolean      @default(true)
  uploadedAt  DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications Application[]

  @@index([userId, type])
}

// ─── JOB LISTINGS ─────────────────────────────────────────────────────────────

model JobListing {
  id           String    @id @default(cuid())
  externalId   String
  provider     String
  title        String
  company      String
  location     String?
  workMode     WorkMode?
  jobType      JobType?
  description  String    @db.Text
  requirements String[]
  salaryMin    Int?
  salaryMax    Int?
  currency     String?
  applyUrl     String
  status       JobStatus @default(OPEN)
  postedAt     DateTime?
  expiresAt    DateTime?
  rawData      Json?
  fetchedAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  matches JobMatch[]

  @@unique([externalId, provider])
  @@index([provider])
  @@index([status])
  @@index([company])
}

// ─── JOB MATCHES ──────────────────────────────────────────────────────────────

model JobMatch {
  id           String      @id @default(cuid())
  userId       String
  jobListingId String
  score        Int         // 0–100
  aiReasoning  String?     @db.Text
  status       MatchStatus @default(PENDING)
  analyzedAt   DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobListing  JobListing  @relation(fields: [jobListingId], references: [id], onDelete: Cascade)
  application Application?

  @@unique([userId, jobListingId])
  @@index([userId, status])
  @@index([score])
}

// ─── APPLICATIONS ─────────────────────────────────────────────────────────────

model Application {
  id            String            @id @default(cuid())
  userId        String
  jobMatchId    String            @unique
  documentId    String?
  status        ApplicationStatus @default(DRAFT)
  method        ApplicationMethod @default(PORTAL)
  coverLetter   String?           @db.Text
  customAnswers Json?
  submittedAt   DateTime?
  responseAt    DateTime?
  notes         String?           @db.Text
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobMatch JobMatch         @relation(fields: [jobMatchId], references: [id], onDelete: Cascade)
  document Document?        @relation(fields: [documentId], references: [id])
  logs     ApplicationLog[]

  @@index([userId, status])
  @@index([submittedAt])
}

model ApplicationLog {
  id            String   @id @default(cuid())
  applicationId String
  level         LogLevel @default(INFO)
  event         String
  message       String   @db.Text
  metadata      Json?
  createdAt     DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([createdAt])
}
